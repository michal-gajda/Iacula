{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "otlp-route": {
        "ClusterId": "otlp-collector",
        "Match": {
          "Path": "/otlp/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/otlp"
          }
        ]
      }
    },
    "Clusters": {
      "otlp-collector": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:4318"
          }
        }
      }
    }
  }
}
